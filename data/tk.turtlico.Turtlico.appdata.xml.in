<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop">
	<id>tk.turtlico.Turtlico.desktop</id>
  <name>Turtlico</name>
  <summary>The easy programming tool</summary>
  <description>
    <p>
	    Turtlico is a tool for learning programming basics. You can create programs with icons.
    </p>
	</description>

  <url type="homepage">https://turtlico.gitlab.io</url>
  <screenshots>
		<screenshot width="836" height="448" type="default">
      <image>https://turtlico.gitlab.io/ss-2.png</image>
      <caption>Turtlico main window</caption>
    </screenshot>
	​</screenshots>
  <launchable type="desktop-id">tk.turtlico.Turtlico.desktop</launchable>

  <releases>
    <release version="0.4" date="2020-06-21">
      <description>
        <p>
          This release contains bug fixes and new features:
        </p>
        <ul>
          <li>Added scenes</li>
          <li>Added functions dialog</li>
          <li>Improved help</li>
          <li>Many other smaller improvements</li>
        </ul>
      </description>
    </release>
    <release version="0.3" date="2020-01-03">
      <description>
        <p>
          New major release.
        </p>
      </description>
    </release>
    <release version="0.1" date="2019-09-17">
      <description>
        <p>
          Initial release.
        </p>
      </description>
    </release>
  </releases>

