		{
			"id": "tcf_readlines",
			"code": "def tcf_readlines(file=None):\
	if file == None: file = __file__ + '.save'\
	f = open(file, 'r'); ret = f.readlines(); f.close()\
	ret = [x.replace('\\n', '') for x in ret]\
	return ret"
		},
		{
			"id": "tcf_writelines",
			"code": "def tcf_writelines(data, file=None):\
	if file == None: file = __file__ + '.save'\
	data = [x + '\\n' for x in data]\
	f = open(file, 'w'); f.writelines(data); f.close()"
		},
		{
			"id": "tcf_filedialog",
			"code": "def tcf_filedialog(text = 'Choose a file', filter = 'All files | *', save = False):\
	if sys.platform.startswith('linux'):\
		from subprocess import Popen, PIPE\
		my_env=os.environ.copy()\
		my_env['G_MESSAGES_DEBUG']=''\
		if save: save = '--save'\
		else: save = ''\
		proc = Popen(['zenity', '--file-selection', '--title', text,\
                	 '--file-filter', filter, save], stdout=PIPE, env=my_env)\
		(output, err) = proc.communicate(); proc.wait()\
		output = output.decode().replace('\\n', ''); return output\
	else:\
		f = filter.split(' | ')\
		if len(f) == 2:\
			filetypes = ((f[0], f[1]),)\
		elif len(f) == 1:\
			filetypes = (('Files', f[0]),)\
		from tkinter import filedialog\
		if save:\
			path = filedialog.asksaveasfilename(title=text, filetypes=filetypes)\
			return path\
		else:\
			path = filedialog.askopenfile(title=text, filetypes=filetypes)\
			return path.name"
		},
		{
			"id": "tcf_filedirdel",
			"code": "def tcf_filedirdel(path):\
	if os.path.isfile(path):\
		os.remove(path)\
	elif os.path.isdir(path):\
		import shutil\
		shutil.rmtree(path)\
	else: raise Exception('File or directory {} does not exist!'.format(path))"
		},
		{
			"id": "tcf_place_img",
			"code": "def tcf_place_img(image, t=None):\
	turt = Turtle()\
	turt.shape(image)\
	if t != None:\
		turt.setpos(t.pos())\
	else:\
		turt.setpos(pos())\
	return turt"
		},
		{
			"id": "tcf_get_image",
			"code": "def tcf_get_image(path):\
	if not path in getshapes():\
		if not path.endswith('.gif'):\
			p = Image.open(path)\
			output = NamedTemporaryFile(suffix='.gif')\
			p.save(output, 'GIF')\
			register_shape(output.name)\
			return output.name\
		else:\
			register_shape(path)\
	return path"
		},
		{
			"id": "tcf_collision",
			"code": "tcf_collisions=[]\
def check():\
	for c in tcf_collisions:\
		if not (c[0].isvisible() and c[1].isvisible()):\
			continue\
		if c[0].distance(c[1].xcor(), c[1].ycor()) < c[3] + c [4]:\
			if c[5] != None:\
				c[2](c[5])\
			else:\
				c[2]()\
	ontimer(check, 50)\
check()\
def tcf_collision(a, b, callback, collider_size_1=10, collider_size_2=10, user_data=None):\
	tcf_collisions.append((a, b, callback, collider_size_1, collider_size_2, user_data))"
		},
		{
			"id": "tcf_collision_rect",
			"code": "tcf_collisions_rect=[]\
def check_rect():\
	for c in tcf_collisions_rect:\
		if not (c[0].isvisible() and c[1].isvisible()):\
			continue\
		f_top_right_x = c[0].xcor()+c[3][0]/2\
		f_top_right_y = c[0].ycor()+c[3][1]/2\
		f_bottom_left_x = c[0].xcor()-c[3][0]/2\
		f_bottom_left_y = c[0].ycor()-c[3][1]/2\
		s_top_right_x = c[1].xcor()+c[4][0]/2\
		s_top_right_y = c[1].ycor()+c[4][1]/2\
		s_bottom_left_x = c[1].xcor()-c[4][0]/2\
		s_bottom_left_y = c[1].ycor()-c[4][1]/2\
		if not (f_top_right_x < s_bottom_left_x or f_bottom_left_x > s_top_right_x or f_top_right_y < s_bottom_left_y or f_bottom_left_y > s_top_right_y):\
			if c[5] != None:\
				c[2](c[5])\
			else:\
				c[2]()\
	ontimer(check_rect, 50)\
check_rect()\
def tcf_collision_rect(a, b, callback, collider_size_1=(15, 15), collider_size_2=(15, 15), user_data=None):\
	tcf_collisions_rect.append((a, b, callback, collider_size_1, collider_size_2, user_data))"
		},
		{
			"id": "tcf_subfiles",
			"code": "def tcf_subfiles(path):\
	result = []\
	for entry in os.scandir(path):\
		if entry.is_file():\
			result.append(entry.path)\
	result.sort()\
	return result"
		},
		{
			"id": "tcf_subdirs",
			"code": "def tcf_subdirs(path):\
	result = []\
	for entry in os.scandir(path):\
		if entry.is_dir():\
			result.append(entry.path)\
	result.sort()\
	return result"
		},
		{
			"id": "tcf_index",
			"code": "def tcf_index(list, item, start=0, direction=1):\
	if direction == 0: raise Exception('Direction can not bet zero.')\
	if direction < 0: end = 0\
	if direction >0: end = len(list)\
	for i in range(start, end, direction):\
		if list[i] == item:\
			return i\
	return -1"
		}
	]
