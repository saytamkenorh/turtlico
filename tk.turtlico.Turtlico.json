{
    "app-id": "tk.turtlico.Turtlico",
    "runtime": "org.gnome.Platform",
    "runtime-version": "3.34",
    "sdk": "org.gnome.Sdk",
    "command": "turtlico",
    "finish-args": [
        "--share=network",
        "--share=ipc",
        "--socket=x11",
        "--socket=wayland",
        "--filesystem=xdg-run/dconf",
        "--filesystem=~/.config/dconf:ro",
        "--filesystem=host",
        "--talk-name=ca.desrt.dconf",
        "--talk-name=org.freedesktop.Flatpak",
        "--env=DCONF_USER_CONFIG_DIR=.config/dconf"
    ],
    "cleanup": [
        "/include",
        "/lib/pkgconfig",
        "/lib/debug",
        "/man",
        "/share/doc",
        "/share/gtk-doc",
        "/share/man",
        "/share/pkgconfig",
        "/share/vala",
        "*.la",
        "*.a"
    ],
    "modules": [
        {
            "name" : "gtksourceview",
            "builddir": true,
            "buildsystem": "meson",
            "sources" : [
                {
                    "type" : "git",
                    "url" : "https://gitlab.gnome.org/GNOME/gtksourceview.git"
                }
            ]
	    },
	    {
            "name" : "tcl",
            "sources" : [
                {
                    "type" : "archive",
                    "url" : "http://prdownloads.sourceforge.net/tcl/tcl8.6.10-src.tar.gz",
                    "sha256" : "5196dbf6638e3df8d5c87b5815c8c2b758496eb6f0e41446596c9a4e638d87ed"
                }
            ],
            "subdir" : "unix",
            "build-options" : {
                "no-debuginfo" : true
            },
            "config-opts": [
                "--enable-threads"
            ],
            "post-install" : [
                "chmod 755 /app/lib/libtcl8.6.so"
            ]
        },
        {
            "name" : "tk",
            "sources" : [
                {
                    "type" : "archive",
                    "url" : "http://prdownloads.sourceforge.net/tcl/tk8.6.10-src.tar.gz",
                    "sha256" : "63df418a859d0a463347f95ded5cd88a3dd3aaa1ceecaeee362194bc30f3e386"
                }
            ],
            "subdir" : "unix",
            "build-options" : {
                "no-debuginfo" : true
            },
            "config-opts": [
                "--with-x",
                "--enable-threads"
            ],
            "post-install" : [
                "chmod 755 /app/lib/libtk8.6.so"
            ]
        },
        {
            "name" : "python3",
            "config-opts" : [
                "--enable-ipv6",
                "--with-threads",
                "--with-lto",
                "--with-system-ffi",
                "--with-system-libmpdec",
                "--with-system-expat"
            ],
            "build-options" : {
                "no-debuginfo" : true
            },
            "cleanup" : [
                "/bin/2to3*",
                "/bin/easy_install*",
                "/bin/idle*",
                "/bin/python*-config",
                "/bin/pyvenv*",
                "/bin/pydoc*",
                "/include",
                "/share",
                "/lib/pkgconfig",
                "/lib/python*/config-*",
                "/lib/python*/test",
                "/lib/python*/distutils/tests",
                "/lib/python*/ctypes/test",
                "/lib/python*/sqlite3/test",
                "/lib/python*/lib2to3/tests",
                "/lib/python*/tkinter/test",
                "/lib/python*/unittest/test",
                "/lib/python*/lib-dynload/_*_test.*.so",
                "/lib/python*/lib-dynload/_test*.*.so",
                "/lib/python*/idlelib",
                "*.pyc",
                "__pycache__",
                "*.exe"
            ],
            "sources" : [
                {
                    "type" : "archive",
                    "url" : "https://www.python.org/ftp/python/3.8.1/Python-3.8.1.tar.xz",
                    "sha256" : "75894117f6db7051c1b34f37410168844bbb357c139a8a10a352e9bf8be594e8"
                }
            ]
        },
        {
            "name": "python3-Pillow",
            "buildsystem": "simple",
            "build-commands": [
                "LDFLAGS=-L/usr/lib/${FLATPAK_ARCH}-linux-gnu pip3 install --no-index --find-links=\"file://${PWD}\" --prefix=/app Pillow"
            ],
            "sources": [
                {
                    "type": "file",
                    "url": "https://files.pythonhosted.org/packages/39/47/f28067b187dd664d205f75b07dcc6e0e95703e134008a14814827eebcaab/Pillow-7.0.0.tar.gz",
                    "sha256": "4d9ed9a64095e031435af120d3c910148067087541131e82b3e8db302f4c8946"
                }
            ]
        },
        {
            "name": "turtlico",
            "builddir": true,
            "buildsystem": "meson",
            "config-opts" : [
                "-Dflatpak=true"
            ],
            "sources": [
                {
                    "type": "git",
                    "url": "file:///home/matyas/Projects/turtlico"
                }
            ]
        }
    ]
}
