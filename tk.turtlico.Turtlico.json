{
    "app-id": "tk.turtlico.Turtlico",
    "runtime": "org.gnome.Platform",
    "runtime-version": "3.34",
    "sdk": "org.gnome.Sdk",
    "command": "turtlico",
    "finish-args": [
        "--share=network",
        "--share=ipc",
        "--socket=x11",
        "--socket=wayland",
        "--filesystem=xdg-run/dconf",
        "--filesystem=~/.config/dconf:ro",
        "--filesystem=host",
        "--talk-name=ca.desrt.dconf",
        "--talk-name=org.freedesktop.Flatpak",
        "--env=DCONF_USER_CONFIG_DIR=.config/dconf"
    ],
    "cleanup": [
        "/include",
        "/lib/pkgconfig",
        "/lib/debug",
        "/man",
        "/share/doc",
        "/share/gtk-doc",
        "/share/man",
        "/share/pkgconfig",
        "/share/vala",
        "*.la",
        "*.a"
    ],
    "modules": [
        {
            "name" : "gtksourceview",
            "builddir": true,
            "buildsystem": "meson",
            "sources" : [
                {
                    "type" : "git",
                    "url" : "https://gitlab.gnome.org/GNOME/gtksourceview.git"
                }
            ]
	},
        {
            "name": "turtlico",
            "builddir": true,
            "buildsystem": "meson",
            "config-opts" : [
                "-Dflatpak=true"
            ],
            "sources": [
                {
                    "type": "git",
                    "url": "file:///home/matyas/Projects/turtlico"
                }
            ]
        }
    ]
}
