import os
import sys
import signal

turtlico_dir = os.path.dirname(os.path.dirname(os.path.abspath(__file__)))
pkgdatadir = os.path.join(turtlico_dir, 'share', 'turtlico')

sys.path.insert(1, pkgdatadir)

def main():
    from gi.repository import Gio
    resource = Gio.Resource.load(
        os.path.join(pkgdatadir, 'io.gitlab.Turtlico.gresource'))
    resource._register()

    from turtlico.app.application import Application
    from turtlico.locale import _
    app = Application()
    signal.signal(signal.SIGINT, signal.SIG_DFL)
    return app.run(sys.argv)


if __name__ == '__main__':
    sys.exit(main())
